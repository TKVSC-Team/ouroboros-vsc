{
  "name": "ouroboros-vsc",
  "displayName": "Ouroboros VSC",
  "description": "Dev tools for the Ouroboros project.",
  "version": "0.0.1",
  "icon": "icon.png",
  "publisher": "TKVSC-Team",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TKVSC-Team/ouroboros-vsc"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ouroborosVSC.copyToIn",
        "title": "Copy to CPP_IN"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ouroborosVSC.copyToIn",
          "when": "resourcePath =~ /CPP_OUT/ && !explorerResourceIsFolder",
          "group": "7_modification"
        }
      ],
      "editor/title/context": [
        {
          "command": "ouroborosVSC.copyToIn",
          "when": "resourcePath =~ /CPP_OUT/",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "ouroborosVSC.copyToIn",
          "when": "resourcePath =~ /CPP_OUT/",
          "group": "1_modification"
        }
      ],
      "commandPalette": [
        {
          "command": "ouroborosVSC.copyToIn",
          "when": "resourcePath =~ /CPP_OUT/"
        }
      ]
    }
  }
}
